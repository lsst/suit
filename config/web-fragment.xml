<web-fragment>
<!--url mapper-->
    <servlet>
        <servlet-name>timeseries</servlet-name>
        <jsp-file>/ts.html</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>timeseries</servlet-name>
        <url-pattern>/timeseries</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>alertviewer</servlet-name>
        <jsp-file>/alertviewer.html</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>alertviewer</servlet-name>
        <url-pattern>/alertviewer/*</url-pattern>
    </servlet-mapping>


</web-fragment>
